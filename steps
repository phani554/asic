constraints.sdc :

# 1. Define a Virtual Clock
# Since RCA is combinational, we create a clock to serve as a timing reference.
# Period of 10.0ns = 100MHz target frequency.
create_clock -name virtual_clk -period 10.0

# 2. Constrain Input Paths
# Assume inputs (a, b, cin) arrive 2ns after the start of the clock cycle.
set_input_delay -clock virtual_clk 2.0 [get_ports {a[*]}]
set_input_delay -clock virtual_clk 2.0 [get_ports {b[*]}]
set_input_delay -clock virtual_clk 2.0 [get_ports {cin}]

# 3. Constrain Output Paths
# Assume outputs (sum, cout) must be stable 2ns before the next clock cycle.
set_output_delay -clock virtual_clk 2.0 [get_ports {sum[*]}]
set_output_delay -clock virtual_clk 2.0 [get_ports {cout}]

# 4. Max Delay (The "Critical Path" Constraint)
# This is vital for RCA. It ensures the carry ripple from a[0] to cout
# does not exceed a specific time (e.g., 8ns).
set_max_delay 8.0 -from [all_inputs] -to [all_outputs]

# 5. Environment and Loads
# Set a typical load on output pins to simulate real-world wire capacitance.
set_load 0.1 [all_outputs]

# Set the driving strength of the input signals
set_driving_cell -lib_cell BUFX2 [all_inputs] 
